SAM_GOV_API_KEY=your_key_here      # free at api.sam.gov/cs/ui/
ANTHROPIC_API_KEY=sk-ant-...        # claude.ai/settings/api-keys
DB_PATH=./scanner.db
DIGEST_OUTPUT=./digests             # folder for daily markdown digests
MIN_SCORE=6                         # minimum AI fit score (1-10) to include in digest
STATES=                             # comma-sep 2-letter codes (e.g. CA,TX,NY). Empty = all 50+DC
FPDS_NAICS=541511,541512,541519,541611,541715,518210,541990  # award-intel NAICS codes
